<main>
    <div class="container py-5 mt-5">
        <div class="card mb-3 bg-dark text-light mx-auto" style="max-width: 900px;">
            <div class="row g-0">
                <div class="col-md-6">
                    <div class="card-body p-5">
                        <h4 class="card-title text-uppercase mb-4">Acceder :</h4>
                        
                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger py-2 text-center" role="alert">
                                @ViewBag.Error
                            </div>
                        }

                        <form asp-controller="Home" asp-action="IniciarSesion" method="post">
                            <div class="row">
                                <div class="col text-dark">
                                    <div class="form-floating mb-4">
                                        <input type="email" name="correo" class="form-control" id="floatingInput" placeholder="name@example.com" required>
                                        <label for="floatingInput">Correo Electrónico</label>
                                    </div>
                                    <div class="form-floating mb-4">
                                        <input type="password" name="contraseña" class="form-control" id="floatingPassword" placeholder="Contraseña" required>
                                        <label for="floatingPassword">Contraseña</label>
                                    </div>
                                    <p class="text-center text-light mt-4" style="font-size: 0.9rem;">
                                        Regístrese con este enlace ->
                                        <a asp-controller="Home" asp-action="Registrarse" class="pe-auto text-info text-decoration-none">Crear Cuenta</a>
                                    </p>
                                </div>
                                <div class="text-center py-2">
                                    <button type="submit" class="btn btn-danger w-50 fw-bold" style="font-size: 0.9rem;">INICIAR SESIÓN</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
                <div class="col-md-6">
                    <img src="~/imgGYM/Gym-Interior/WORKERS.png"
                         class="img-fluid rounded-end h-100 w-100"
                         style="object-fit: cover; object-position: center;"
                         alt="Workers Gym">
                </div>
            </div>
        </div>
    </div>
</main>