@{
    ViewData["Title"] = "Carrito";
}

<main>
    <section class="bg-black text-light py-5 mb-5 shadow">
        <div class="container">
            <div class="row justify-content-center text-center">
                <div class="col-md-8">
                    <h1 class="display-4 fw-bold">CARRITO DE <span class="text-danger">COMPRAS</span></h1>
                    <p class="lead text-secondary text-uppercase" style="letter-spacing: 3px;">SE MOSTRARAN LOS PRODUCTOS QUE AÑADIO</p>
                    <hr class="border-light border-2 opacity-25 w-25 mx-auto">
                </div>
            </div>
        </div>
    </section>

    <div class="container">
        <div class="row">
            <h2 class="mb-3 fw-bold">Tu Carrito esta <span id="productos-escogidos" class="text-danger">Vacio</span></h2>
            <div class="table-responsive shadow-sm rounded">
                <table class="table table-hover align-middle bg-white">
                    <thead class="table-dark">
                        <tr>
                            <th scope="col" style="width: 100px;">Producto</th>
                            <th scope="col">Descripción</th>
                            <th scope="col">Fecha de Compra</th>
                            <th scope="col">Precio Total</th>
                        </tr>
                    </thead>
                    <tbody id="tabla-compras">
                        <tr>
                            <td>
                                <img src="~/imgGYM/imagenMoises.jpg" class="img-thumbnail" alt="Proteína" style="width: 60px; height: 60px; object-fit: cover;">
                            </td>
                            <td>
                                <span class="fw-bold">Proteína Marido Moisés</span><br>
                                <small class="text-muted">Categoría: Suplementos</small>
                            </td>
                            <td>08 de Abril, 2026</td>
                            <td class="fw-bold text-danger">S/ 200.00</td>
                        </tr>
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">
                                <i class="bi bi-plus-circle me-2"></i> Los próximos productos que agregues aparecerán aquí...
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="container mb-5 px-5 bg-dark text-light shadow py-3">
        <div class="row align-items-center">
            <div class="col-9">
                <p class="text-center fw-bold mb-0">Total estimado</p>
            </div>
            <div class="col-3 border-start border-secondary">
                <p class="text-center fw-bold mb-0 text-danger">S/ 200.00</p>
            </div>
        </div>
    </div>
</main>