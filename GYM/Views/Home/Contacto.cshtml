<main>
    <section class="bg-black text-light py-5 mb-3 shadow">
        <div class="container">
            <div class="row justify-content-center text-center">
                <div class="col-md-8">
                    <h1 class="display-4 fw-bold">¡Únete a la Familia <span class="text-danger">WORKERS!</span></h1>
                    <p class="lead text-secondary text-uppercase" style="letter-spacing: 3px;">Ingrese sus datos para mayor informacion sobre las clases</p>
                    <hr class="border-light border-2 opacity-25 w-25 mx-auto">
                </div>
            </div>
        </div>
    </section>

    <!-- carta de datos -->
    <div class="container py-5">
        <div class="card mb-3 bg-dark text-light">
            <div class="row g-0">
                <div class="col-md-8">
                    <div class="card-body">
                        <h4 class="card-title">Ingrese sus Datos :</h4>
                        <hr class="border-light border-2 opacity-25 w-9 mx-auto">
                        <div class="row">
                            <div class="col text-dark">
                                <div class="form-floating mb-3">
                                    <input type="text" class="form-control" id="floatingName" placeholder="Tu nombre">
                                    <label for="floatingName">Nombre Completo</label>
                                </div>
                            </div>
                            <div class="col text-dark">
                                <div class="form-floating mb-3">
                                    <input type="email" class="form-control" id="floatingInput" placeholder="name@example.com">
                                    <label for="floatingInput">Correo Electronico</label>
                                </div>
                            </div>
                        </div>
                        <!--comentarios-->
                        <div class="col text-dark py-3">
                            <div class="form-floating">
                                <textarea class="form-control" placeholder="Consulta" id="floatingTextarea2" style="height: 150px"></textarea>
                                <label for="floatingTextarea2">Comentario</label>
                            </div>
                        </div>
                        <div class="text-center py-2">
                            <button type="submit" class="btn btn-danger w-50 fw-bold" style="font-size: 0.9rem;">ENVIAR MENSAJE</button>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <img src="imgGYM/Gym-Interior/WORKERS.png"
                         class="img-fluid rounded-end h-100 w-100"
                         style="height: 150px"
                         alt="...">
                </div>
            </div>
        </div>
    </div>
</main>