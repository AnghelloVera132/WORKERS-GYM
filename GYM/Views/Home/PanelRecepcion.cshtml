@{
    ViewData["Title"] = "Panel Recepción";
    var nombre = Context.Session.GetString("UsuarioNombre") ?? "Recepción";
}

<div class="container py-5">

    <div class="bg-dark text-light rounded-4 shadow p-5 mb-5">
        <p class="text-uppercase text-secondary mb-2"
           style="letter-spacing: 3px;">
            Panel de recepción
        </p>

        <h1 class="fw-bold mb-2">
            Bienvenido, <span class="text-danger">@nombre</span>
        </h1>

        <p class="mb-0 text-light opacity-75">
            Gestiona la atención de clientes, membresías,
            pagos y asistencias del gimnasio Workers.
        </p>
    </div>

    <div class="row g-4">

        <!-- MIEMBROS -->
        <div class="col-md-4">
            <div class="card shadow border-0 h-100 rounded-4">
                <div class="card-body p-4">

                    <i class="bi bi-people-fill fs-1 text-danger"></i>

                    <h5 class="fw-bold mt-3">
                        Miembros
                    </h5>

                    <p class="text-muted">
                        Busca y consulta clientes registrados en el sistema.
                    </p>

                    <a asp-controller="Miembros"
                       asp-action="Index"
                       class="btn btn-danger w-100">
                        Ver miembros
                    </a>

                </div>
            </div>
        </div>

        <!-- MEMBRESÍAS -->
        <div class="col-md-4">
            <div class="card shadow border-0 h-100 rounded-4">
                <div class="card-body p-4">

                    <i class="bi bi-card-checklist fs-1 text-danger"></i>

                    <h5 class="fw-bold mt-3">
                        Membresías
                    </h5>

                    <p class="text-muted">
                        Registra y consulta membresías por DNI del cliente.
                    </p>

                    <a asp-controller="Membresias"
                       asp-action="Index"
                       class="btn btn-danger w-100">
                        Gestionar
                    </a>

                </div>
            </div>
        </div>

        <!-- PAGOS -->
        <div class="col-md-4">
            <div class="card shadow border-0 h-100 rounded-4">
                <div class="card-body p-4">

                    <i class="bi bi-cash-coin fs-1 text-dark"></i>

                    <h5 class="fw-bold mt-3">
                        Pagos
                    </h5>

                    <p class="text-muted">
                        Consulta los pagos realizados por los clientes.
                    </p>

                    <a asp-controller="Pagos"
                       asp-action="Index"
                       class="btn btn-dark w-100">
                        Ver pagos
                    </a>

                </div>
            </div>
        </div>

        <!-- ASISTENCIAS -->
        <div class="col-md-4">
            <div class="card shadow border-0 h-100 rounded-4">
                <div class="card-body p-4">

                    <i class="bi bi-calendar-check-fill fs-1 text-danger"></i>

                    <h5 class="fw-bold mt-3">
                        Asistencias
                    </h5>

                    <p class="text-muted">
                        Registra y consulta los ingresos de miembros al gimnasio.
                    </p>

                    <a asp-controller="Asistencias"
                       asp-action="Index"
                       class="btn btn-danger w-100">
                        Gestionar asistencia
                    </a>

                </div>
            </div>
        </div>

    </div>
</div>