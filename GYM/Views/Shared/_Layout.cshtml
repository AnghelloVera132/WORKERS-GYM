<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - WORKERS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/estilos.css">
</head>

<body>
    <header>
        <div class="container-fluid text-center bg-dark text-light py-4">
            <div class="row">
                <div class="col-4"></div>
                <div class="col-4">
                    <a class="navbar-brand fw-light text-uppercase" asp-controller="Home" asp-action="Index" style="letter-spacing: 5px; font-size: 1.8rem;">
                        <span class="fw-bold">WORKERS</span>
                    </a>
                </div>
                <div class="col-4 d-flex justify-content-end align-items-center pe-4">

                    @{
                        var rol = Context.Session.GetString("UsuarioRol");
                        var nombreUsuario = Context.Session.GetString("UsuarioNombre");
                    }

                    @if (!string.IsNullOrEmpty(rol))
                    {
                        var accionPanel = "PerfilUsu";

                        if (rol == "Administrador")
                        {
                            accionPanel = "PanelAdmin";
                        }
                        else if (rol == "Recepcion")
                        {
                            accionPanel = "PanelRecepcion";
                        }

                        <a asp-controller="Home"
                           asp-action="@accionPanel"
                           class="text-light me-3 text-decoration-none"
                           title="Ir a mi panel">

                            <i class="bi bi-person-circle me-1"></i>

                            @nombreUsuario (@rol)
                        </a>

                        <a asp-controller="Home"
                           asp-action="CerrarSesion"
                           class="btn btn-outline-light btn-sm">
                            Cerrar sesión
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Home"
                           asp-action="IniciarSesion"
                           class="text-light text-decoration-none"
                           title="Iniciar sesión">

                            <i class="bi bi-person-circle"
                               style="font-size: 1.8rem;"></i>
                        </a>
                    }

                </div>
        
        <nav class="navbar navbar-expand-sm bg-body-tertiary">
            <div class="container-fluid">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav mx-auto ps-5">
                        <li class="nav-item ps-5">
                            <a class="nav-link active" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>
                        <li class="nav-item ps-5">
                            <a class="nav-link" asp-controller="Home" asp-action="Horarios">Horarios</a>
                        </li>
                        <li class="nav-item ps-5">
                            <a class="nav-link" asp-controller="Home" asp-action="Contacto">Contacto</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    @RenderBody()

    <footer class="bg-black">
        <div class="container-fluid p-0">
            <div class="card mb-0 bg-black text-light border-0 rounded-0">
                <div class="row g-0 align-items-start py-5">
                    <div class="col-md-4 text-center p-4">
                        <img src="~/imgGYM/Gym-Interior/WORKERS.png" class="img-fluid" alt="Logo" style="max-width: 500px;">
                    </div>
                    <div class="col-md-8">
                        <div class="card-body">
                            <div class="h4 pb-2 mb-4 text-light border-bottom border-light">WORKERS - SJL</div>
                            <p class="card-text mb-5">Entrena con los mejores. Síguenos en nuestras redes y sé parte de la comunidad.</p>
                            <div class="h4 pb-2 mb-4 text-light border-bottom border-light">Nuestras Redes</div>
                            <div class="d-flex gap-4 justify-content-start mt-3 mb-5">
                                <a href="#" class="text-light fs-2"><i class="bi bi-facebook"></i></a>
                                <a href="#" class="text-light fs-2"><i class="bi bi-instagram"></i></a>
                                <a href="#" class="text-light fs-2"><i class="bi bi-tiktok"></i></a>
                                <a href="#" class="text-light fs-2"><i class="bi bi-whatsapp"></i></a>
                            </div>
                            <p class="card-text mt-3">
                                <small class="text-muted">© 2026 WORKERS no tiene los derechos reservados.</small>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>