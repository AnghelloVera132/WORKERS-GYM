@model List<GYM.Models.Miembro>

@{
    ViewData["Title"] = "Miembros";
    var rol = Context.Session.GetString("UsuarioRol");
}

<div class="container py-5">

    <div class="bg-dark text-light rounded-4 shadow p-4 mb-4 d-flex justify-content-between align-items-center">
        <div>
            <p class="text-uppercase text-secondary mb-1" style="letter-spacing: 3px;">
                Gestión
            </p>
            <h2 class="fw-bold mb-1">Miembros</h2>
            <p class="mb-0 text-light opacity-75">
                Consulta de clientes registrados en Workers Gym.
            </p>
        </div>

        @if (rol == "Administrador")
        {
            <a asp-controller="Home" asp-action="PanelAdmin" class="btn btn-outline-light">
                <i class="bi bi-arrow-left me-1"></i>
                Volver al panel
            </a>
        }
        else if (rol == "Recepcion")
        {
            <a asp-controller="Home" asp-action="PanelRecepcion" class="btn btn-outline-light">
                <i class="bi bi-arrow-left me-1"></i>
                Volver al panel
            </a>
        }
    </div>

    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success shadow-sm">@TempData["Exito"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger shadow-sm">@TempData["Error"]</div>
    }

    <div class="card shadow border-0 rounded-4 mb-4">
        <div class="card-body p-4">
            <form asp-controller="Miembros" asp-action="Index" method="get" class="row g-3">
                <div class="col-md-9">
                    <label class="form-label fw-semibold">Buscar por DNI</label>
                    <input type="text"
                           name="dni"
                           value="@ViewBag.DNI"
                           class="form-control"
                           placeholder="Ingrese DNI del miembro"
                           maxlength="8" />
                </div>

                <div class="col-md-3 d-flex gap-2 align-items-end">
                    <button type="submit" class="btn btn-danger w-100">
                        <i class="bi bi-search me-1"></i>
                        Buscar
                    </button>

                    <a asp-controller="Miembros" asp-action="Index" class="btn btn-secondary w-100">
                        Limpiar
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Nombre</th>
                            <th>Apellido</th>
                            <th>DNI</th>
                            <th>Correo</th>
                            <th>Rol</th>
                            <th>Fecha registro</th>

                            @if (rol == "Administrador")
                            {
                                <th>Acción</th>
                            }
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model.Count == 0)
                        {
                            <tr>
                                <td colspan="@(rol == "Administrador" ? 7 : 6)"
                                    class="text-center py-5 text-muted">
                                    <i class="bi bi-person-x fs-2 d-block mb-2"></i>
                                    No se encontraron miembros.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-semibold">@item.Nombre</td>
                                    <td>@item.Apellido</td>
                                    <td>@item.DNI</td>
                                    <td>@item.Correo</td>
                                    <td>
                                        @if (item.Rol == "Administrador")
                                        {
                                            <span class="badge bg-danger">@item.Rol</span>
                                        }
                                        else if (item.Rol == "Recepcion")
                                        {
                                            <span class="badge bg-dark">@item.Rol</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">@item.Rol</span>
                                        }
                                    </td>
                                    <td>@item.FechaRegistro.ToString("dd/MM/yyyy")</td>

                                    @if (rol == "Administrador")
                                    {
                                        <td>
                                            <form asp-controller="Miembros"
                                                  asp-action="Eliminar"
                                                  method="post"
                                                  onsubmit="return confirm('¿Seguro que deseas eliminar este miembro?');">

                                                @Html.AntiForgeryToken()

                                                <input type="hidden" name="id" value="@item.Id" />

                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-trash me-1"></i>
                                                    Eliminar
                                                </button>
                                            </form>
                                        </td>
                                    }
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>