@model List<GYM.Models.Asistencia>

@{
    ViewData["Title"] = "Asistencias";
    var rol = Context.Session.GetString("UsuarioRol");
}

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Control de Asistencia</h2>
            <p class="text-muted mb-0">Registro y consulta de ingresos al gimnasio</p>
        </div>

        @if (rol == "Administrador")
        {
            <a asp-controller="Home" asp-action="PanelAdmin" class="btn btn-outline-dark">Volver al panel</a>
        }
        else if (rol == "Recepcion")
        {
            <a asp-controller="Home" asp-action="PanelRecepcion" class="btn btn-outline-dark">Volver al panel</a>
        }
    </div>

    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success">@TempData["Exito"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card shadow border-0 mb-4">
        <div class="card-header bg-dark text-light">
            Registrar asistencia
        </div>

        <div class="card-body">
            <form asp-controller="Asistencias" asp-action="Registrar" method="post" class="row g-3">
                @Html.AntiForgeryToken()

                <div class="col-md-9">
                    <input type="text"
                           name="DNI"
                           class="form-control"
                           placeholder="Ingrese DNI del miembro"
                           maxlength="8"
                           minlength="8"
                           pattern="[0-9]{8}"
                           required />
                </div>

                <div class="col-md-3">
                    <button type="submit" class="btn btn-danger w-100">
                        Registrar asistencia
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow border-0 mb-4">
        <div class="card-header bg-dark text-light">
            Filtrar asistencias
        </div>

        <div class="card-body">
            <form asp-controller="Asistencias" asp-action="Index" method="get" class="row g-3">

                <div class="col-md-4">
                    <label class="form-label">DNI</label>
                    <input type="text"
                           name="dni"
                           value="@ViewBag.DNI"
                           class="form-control"
                           placeholder="DNI del miembro"
                           maxlength="8" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Desde</label>
                    <input type="date"
                           name="fechaDesde"
                           value="@ViewBag.FechaDesde"
                           class="form-control" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Hasta</label>
                    <input type="date"
                           name="fechaHasta"
                           value="@ViewBag.FechaHasta"
                           class="form-control" />
                </div>

                <div class="col-md-2 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-dark w-100">
                        Filtrar
                    </button>
                </div>

                <div class="col-md-12">
                    <a asp-controller="Asistencias" asp-action="Index" class="btn btn-secondary">
                        Limpiar filtros
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow border-0">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Nombre</th>
                        <th>DNI</th>
                        <th>Fecha</th>
                        <th>Hora de entrada</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                No hay asistencias registradas.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Miembro?.Nombre @item.Miembro?.Apellido</td>
                                <td>@item.Miembro?.DNI</td>
                                <td>@item.FechaHoraEntrada.ToString("dd/MM/yyyy")</td>
                                <td>@item.FechaHoraEntrada.ToString("HH:mm:ss")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>